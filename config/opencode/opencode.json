{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": "notify",
    "model": "xai/grok-build-0.1",
    "small_model": "opencode/north-mini-code-free",
    "formatter": true,
    "lsp": true,
    "permission": {
        "external_directory": {
            "~/Documents/Obsidian/Personal Vault/Agent Memory/**": "allow"
        }
    },
    "agent": {
        "explore": {
            "model": "opencode/deepseek-v4-flash-free"
        },
        "build": {
            "permission": {
                "task": {
                    "*": "deny",
                     "brainstorm": "allow",
                     "code-review": "allow",
                     "explore": "allow",
                     "general": "allow"
                }
            }
        },
        "plan": {
            "permission": {
                "task": {
                    "*": "deny",
                     "brainstorm": "allow",
                     "code-review": "allow",
                     "explore": "allow"
                }
            }
        }
    },
    "compaction": {
        "prune": true
    }
}
