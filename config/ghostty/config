theme = Dracula

font-family = "FiraCode Nerd Font"
font-size = 14

adjust-cell-height = 25%
window-padding-x = 14
window-padding-y = 14
window-height = 40
window-width = 175

# Fix "missing or unsuitable terminal: xterm-ghostty" issue
# - https://ghostty.org/docs/help/terminfo#sudo
# - https://ghostty.org/docs/help/terminfo#ssh
shell-integration-features = ssh-terminfo,ssh-env,sudo

# Fix Ctrl + Arrow keys for word jumping in the shell
keybind = ctrl+left=esc:b
keybind = ctrl+right=esc:f